[Unit]
Description=AgentScope Enterprise Agent Platform Backend
After=network.target redis.service

[Service]
Type=simple
User=<REPLACE_WITH_SERVICE_USER>
Group=<REPLACE_WITH_SERVICE_GROUP>
WorkingDirectory=<REPLACE_WITH_PROJECT_ROOT>/agent-platform
EnvironmentFile=<REPLACE_WITH_PROJECT_ROOT>/agent-platform/.env
ExecStart=<REPLACE_WITH_PROJECT_ROOT>/agent-platform/.venv/bin/uvicorn backend.app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
